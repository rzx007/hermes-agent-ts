{
  "name": "hermes-agent-ts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "pnpm -r build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "cli": "pnpm --filter @hermes/cli dev"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "tsup": "^8.1.0",
    "vitest": "^2.0.0",
    "@types/node": "^20.14.0"
  }
}
